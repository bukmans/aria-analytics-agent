# Required — your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — defaults to 3000
PORT=3000

# Optional — override Claude model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional — comma-separated allowed origins for CORS
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-domain.com

# Optional — Power Automate webhook URL (triggered when a manual ticket is finalized)
# Get this from your "When an HTTP request is received" trigger in Power Automate
# POWER_AUTOMATE_WEBHOOK_URL=https://prod-xx.westus.logic.azure.com/workflows/...

# Optional — Email notifications via Gmail SMTP
# Create a Gmail App Password at: myaccount.google.com/apppasswords (requires 2FA)
# SMTP_USER=your.gmail@gmail.com
# SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Analyst routing — map routed_to value to analyst email
# NOTIFY_DATA_ENGINEER=engineer@crs.org
# NOTIFY_DATA_ANALYST=analyst@crs.org
# NOTIFY_DATA_SCIENTIST=datascientist@crs.org
# NOTIFY_ANALYTICS_LEAD=analytics.lead@crs.org
# NOTIFY_TEAM=analytics@crs.org   ← fallback if specific analyst not set
