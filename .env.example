# Required — your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — defaults to 3000
PORT=3000

# Optional — override Claude model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional — comma-separated allowed origins for CORS
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-domain.com

# Optional — Power Automate webhook URL (triggered when a manual ticket is finalized)
# Get this from your "When an HTTP request is received" trigger in Power Automate
# POWER_AUTOMATE_WEBHOOK_URL=https://prod-xx.westus.logic.azure.com/workflows/...
